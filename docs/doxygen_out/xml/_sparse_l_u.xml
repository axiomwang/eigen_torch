    <programlisting>
<codeline><highlight class="normal">#ifndef<sp/>EIGEN_SPARSELU_H</highlight></codeline>
<codeline><highlight class="normal">#define<sp/>EIGEN_SPARSELU_H</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal">#include<sp/>&quot;Matrix.h&quot;</highlight></codeline>
<codeline><highlight class="normal">#include<sp/>&quot;SparseMatrix&quot;</highlight></codeline>
<codeline><highlight class="normal">#include<sp/>&lt;stdexcept&gt;</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal">namespace<sp/>Eigen<sp/>{</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal">template<sp/>&lt;typename<sp/>MatrixType_&gt;</highlight></codeline>
<codeline><highlight class="normal">class<sp/>SparseLU<sp/>{</highlight></codeline>
<codeline><highlight class="normal">public:</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>using<sp/>MatrixType<sp/>=<sp/>MatrixType_;</highlight></codeline>
