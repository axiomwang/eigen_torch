    <compoundname>SVD</compoundname>
    <briefdescription>
    </briefdescription>
    <detaileddescription>
    </detaileddescription>
    <programlisting>
<codeline><highlight class="normal">#pragma<sp/>once</highlight></codeline>
<codeline><highlight class="normal">#include<sp/>&quot;Matrix.h&quot;</highlight></codeline>
<codeline><highlight class="normal">#include<sp/>&lt;tuple&gt;</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal">//<sp/>Torch<sp/>namespaces</highlight></codeline>
<codeline><highlight class="normal">namespace<sp/>Eigen<sp/>{</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal">enum<sp/>{<sp/>ComputeFullU<sp/>=<sp/>1,<sp/>ComputeThinU<sp/>=<sp/>2,<sp/>ComputeFullV<sp/>=<sp/>4,<sp/>ComputeThinV<sp/>=<sp/>8<sp/>};</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal">template<sp/>&lt;typename<sp/>MatrixType&gt;</highlight></codeline>
<codeline><highlight class="normal">class<sp/>JacobiSVD<sp/>{</highlight></codeline>
<codeline><highlight class="normal">protected:</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>at::Tensor<sp/>m_u;</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>at::Tensor<sp/>m_s;</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>at::Tensor<sp/>m_vh;<sp/>//<sp/>Torchs<sp/>return<sp/>V^H,<sp/>Eigen<sp/>SVD<sp/>conventionally<sp/>uses<sp/>V</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>bool<sp/>m_isInitialized<sp/>=<sp/>false;</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>unsigned<sp/>int<sp/>m_computationOptions;</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal">public:</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>JacobiSVD()<sp/>:<sp/>m_computationOptions(0)<sp/>{}</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>explicit<sp/>JacobiSVD(const<sp/>MatrixType&amp;<sp/>matrix,<sp/>unsigned<sp/>int<sp/>computationOptions<sp/>=<sp/>0)<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>compute(matrix,<sp/>computationOptions);</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>}</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>JacobiSVD&amp;<sp/>compute(const<sp/>MatrixType&amp;<sp/>matrix,<sp/>unsigned<sp/>int<sp/>computationOptions<sp/>=<sp/>ComputeThinU<sp/>|<sp/>ComputeThinV)<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>m_computationOptions<sp/>=<sp/>computationOptions;</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>bool<sp/>full_matrices<sp/>=<sp/>(computationOptions<sp/>&amp;<sp/>ComputeFullU)<sp/>||<sp/>(computationOptions<sp/>&amp;<sp/>ComputeFullV);</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>std::tie(m_u,<sp/>m_s,<sp/>m_vh)<sp/>=<sp/>torch::linalg_svd(matrix.tensor(),<sp/>full_matrices);</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>m_isInitialized<sp/>=<sp/>true;</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>return<sp/>*this;</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>}</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>template<sp/>&lt;typename<sp/>Rhs&gt;</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>Rhs<sp/>solve(const<sp/>Rhs&amp;<sp/>b)<sp/>const<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>//<sp/>A<sp/>x<sp/>=<sp/>b<sp/><sp/>--&gt;<sp/>U<sp/>S<sp/>V^T<sp/>x<sp/>=<sp/>b<sp/>--&gt;<sp/>x<sp/>=<sp/>V<sp/>S^{-1}<sp/>U^T<sp/>b</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>//<sp/>In<sp/>PyTorch,<sp/>SVD<sp/>returns<sp/>U,<sp/>S,<sp/>Vh.</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>//<sp/>1.<sp/>Calculate<sp/>U^T<sp/>b</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>auto<sp/>ut_b<sp/>=<sp/>torch::matmul(m_u.adjoint(),<sp/>b.tensor());</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>//<sp/>2.<sp/>Divide<sp/>by<sp/>S</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>//<sp/>Ensure<sp/>shapes<sp/>align<sp/>(broadcast<sp/>S<sp/>correctly)</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>auto<sp/>s_inv_ut_b<sp/>=<sp/>ut_b<sp/>/<sp/>m_s.unsqueeze(-1);</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/></highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>//<sp/>3.<sp/>Multiply<sp/>by<sp/>V<sp/>(which<sp/>is<sp/>Vh^T)</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>at::Tensor<sp/>result<sp/>=<sp/>torch::matmul(m_vh.adjoint(),<sp/>s_inv_ut_b);</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>return<sp/>Rhs(result);</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>}</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>Matrix&lt;typename<sp/>MatrixType::ScalarType,<sp/>Dynamic,<sp/>1&gt;<sp/>singularValues()<sp/>const<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>return<sp/>Matrix&lt;typename<sp/>MatrixType::Scalar,<sp/>Dynamic,<sp/>1&gt;(m_s.unsqueeze(1));</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>}</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>MatrixType<sp/>matrixU()<sp/>const<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>return<sp/>MatrixType(m_u);</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>}</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>MatrixType<sp/>matrixV()<sp/>const<sp/>{</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>return<sp/>MatrixType(m_vh.adjoint());</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/>}</highlight></codeline>
<codeline><highlight class="normal">};</highlight></codeline>
<codeline></codeline>
<codeline><highlight class="normal">}<sp/>//<sp/>namespace<sp/>Eigen</highlight></codeline>
    </programlisting>
