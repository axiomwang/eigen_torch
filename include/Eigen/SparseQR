#ifndef EIGEN_SPARSEQR_H
#define EIGEN_SPARSEQR_H

#include "Matrix.h"
#include "SparseCommon"
#include "SparseMatrix"
#include <optional>
#include <tuple>
#include <stdexcept>

namespace Eigen {

template <typename MatrixType_, typename OrderingType_ = void>
class SparseQR {
public:
    using MatrixType = MatrixType_;
    using Scalar = typename MatrixType::ScalarType;
    using OrderingType = OrderingType_;

protected:
    at::Tensor m_system;
    at::Tensor m_q;
    at::Tensor m_r;

    ComputationInfo m_info = InvalidInput;
    bool m_patternAnalyzed = false;
    bool m_isInitialized = false;
    bool m_usedDenseFallback = false;

    void factorizeTensor(const at::Tensor& matrix) {
        at::Tensor work = matrix;

        try {
            std::tie(m_q, m_r) = torch::linalg_qr(work, "reduced");
            m_usedDenseFallback = false;
            m_info = Success;
        } catch (const std::exception&) {
            at::Tensor dense = work.is_sparse() || work.is_sparse_csr() ? work.to_dense() : work;
            std::tie(m_q, m_r) = torch::linalg_qr(dense, "reduced");
            m_usedDenseFallback = true;
            m_info = Success;
        }

        m_isInitialized = true;
    }

public:
    SparseQR() {}

    explicit SparseQR(const MatrixType& matrix) {
        compute(matrix);
    }

    SparseQR& analyzePattern(const MatrixType& matrix) {
        m_system = matrix.tensor();
        m_patternAnalyzed = true;
        m_info = Success;
        return *this;
    }

    SparseQR& analyzePattern(const at::Tensor& matrix) {
        m_system = matrix;
        m_patternAnalyzed = true;
        m_info = Success;
        return *this;
    }

    SparseQR& factorize(const MatrixType& matrix) {
        m_system = matrix.tensor();
        m_patternAnalyzed = true;
        factorizeTensor(m_system);
        return *this;
    }

    SparseQR& factorize(const at::Tensor& matrix) {
        m_system = matrix;
        m_patternAnalyzed = true;
        factorizeTensor(m_system);
        return *this;
    }

    SparseQR& compute(const MatrixType& matrix) {
        analyzePattern(matrix);
        factorize(matrix);
        return *this;
    }

    template <typename Rhs>
    Rhs solve(const Rhs& b) const {
        if (!m_isInitialized) {
            throw std::runtime_error("SparseQR is not initialized.");
        }

        at::Tensor dense_b;
        if (b.tensor().is_sparse()) {
            dense_b = b.tensor().to_dense();
        } else {
            dense_b = b.tensor();
        }
        
        at::Tensor result;
        try {
            at::Tensor rhs = torch::matmul(m_q.transpose(-2, -1), dense_b);
            result = torch::linalg_solve_triangular(m_r, rhs, /*upper=*/true, /*left=*/true);
        } catch (const std::exception&) {
            at::Tensor dense_system =
                m_system.defined() && (m_system.is_sparse() || m_system.is_sparse_csr())
                    ? m_system.to_dense()
                    : m_system;
            auto out = at::linalg_lstsq(dense_system, dense_b, /*rcond=*/std::nullopt, /*driver=*/std::nullopt);
            result = std::get<0>(out);
        }

        return Rhs(result);
    }

    ComputationInfo info() const { return m_info; }

    int rows() const {
        return m_system.defined() ? static_cast<int>(m_system.size(0)) : 0;
    }

    int cols() const {
        return m_system.defined() ? static_cast<int>(m_system.size(1)) : 0;
    }

    Matrix<Scalar, Dynamic, Dynamic> matrixQ() const { return Matrix<Scalar, Dynamic, Dynamic>(m_q); }
    Matrix<Scalar, Dynamic, Dynamic> matrixR() const { return Matrix<Scalar, Dynamic, Dynamic>(m_r); }

    const at::Tensor& matrixQTensor() const { return m_q; }
    const at::Tensor& matrixRTensor() const { return m_r; }
    bool usedDenseFallback() const { return m_usedDenseFallback; }
};

} // namespace Eigen

#endif // EIGEN_SPARSEQR_H
