#pragma once
#include "Matrix.h"
#include <tuple>

// Torch namespaces
namespace Eigen {

enum { ComputeFullU = 1, ComputeThinU = 2, ComputeFullV = 4, ComputeThinV = 8 };

template <typename MatrixType>
class JacobiSVD {
protected:
    at::Tensor m_u;
    at::Tensor m_s;
    at::Tensor m_vh; // Torchs return V^H, Eigen SVD conventionally uses V
    bool m_isInitialized = false;
    unsigned int m_computationOptions;

public:
    JacobiSVD() : m_computationOptions(0) {}

    explicit JacobiSVD(const MatrixType& matrix, unsigned int computationOptions = 0) {
        compute(matrix, computationOptions);
    }

    JacobiSVD& compute(const MatrixType& matrix, unsigned int computationOptions = ComputeThinU | ComputeThinV) {
        m_computationOptions = computationOptions;
        bool full_matrices = (computationOptions & ComputeFullU) || (computationOptions & ComputeFullV);
        
        std::tie(m_u, m_s, m_vh) = torch::linalg_svd(matrix.tensor(), full_matrices);
        m_isInitialized = true;
        return *this;
    }

    template <typename Rhs>
    Rhs solve(const Rhs& b) const {
        // A x = b  --> U S V^T x = b --> x = V S^{-1} U^T b
        // In PyTorch, SVD returns U, S, Vh.
        
        // 1. Calculate U^T b
        auto ut_b = torch::matmul(m_u.adjoint(), b.tensor());
        
        // 2. Divide by S
        // Ensure shapes align (broadcast S correctly)
        auto s_inv_ut_b = ut_b / m_s.unsqueeze(-1);
        
        // 3. Multiply by V (which is Vh^T)
        at::Tensor result = torch::matmul(m_vh.adjoint(), s_inv_ut_b);
        return Rhs(result);
    }

    Matrix<typename MatrixType::ScalarType, Dynamic, 1> singularValues() const {
        return Matrix<typename MatrixType::ScalarType, Dynamic, 1>(m_s.unsqueeze(1));
    }

    MatrixType matrixU() const {
        return MatrixType(m_u);
    }

    MatrixType matrixV() const {
        return MatrixType(m_vh.adjoint());
    }
};

template <typename MatrixType>
class BDCSVD : public JacobiSVD<MatrixType> {
public:
    BDCSVD() : JacobiSVD<MatrixType>() {}

    explicit BDCSVD(const MatrixType& matrix, unsigned int computationOptions = 0)
        : JacobiSVD<MatrixType>(matrix, computationOptions) {}

    using JacobiSVD<MatrixType>::compute;
    using JacobiSVD<MatrixType>::solve;
    using JacobiSVD<MatrixType>::singularValues;
    using JacobiSVD<MatrixType>::matrixU;
    using JacobiSVD<MatrixType>::matrixV;
};

} // namespace Eigen
