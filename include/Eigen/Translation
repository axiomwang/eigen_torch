#pragma once
#include "Matrix.h"

namespace Eigen {

template <typename Scalar, int Dim>
class Translation {
protected:
    Matrix<Scalar, Dim, 1> m_translation;

public:
    Translation() {
        m_translation = Matrix<Scalar, Dim, 1>::Zero(Dim, 1);
    }

    Translation(Scalar x, Scalar y) {
        static_assert(Dim == 2, "Translation(x, y) is only valid for 2D translations");
        auto options = torch::TensorOptions()
            .dtype(Matrix<Scalar, Dim, 1>::get_torch_dtype())
            .device(DeviceManager::get_default_device());
        m_translation = Matrix<Scalar, Dim, 1>(torch::tensor({x, y}, options).unsqueeze(1));
    }

    Translation(Scalar x, Scalar y, Scalar z) {
        static_assert(Dim == 3, "Translation(x, y, z) is only valid for 3D translations");
        auto options = torch::TensorOptions()
            .dtype(Matrix<Scalar, Dim, 1>::get_torch_dtype())
            .device(DeviceManager::get_default_device());
        m_translation = Matrix<Scalar, Dim, 1>(torch::tensor({x, y, z}, options).unsqueeze(1));
    }

    explicit Translation(const Matrix<Scalar, Dim, 1>& vec) : m_translation(vec) {}

    const Matrix<Scalar, Dim, 1>& vector() const { return m_translation; }
    Matrix<Scalar, Dim, 1>& vector() { return m_translation; }

    Scalar x() const { return m_translation.tensor()[0][0].template item<Scalar>(); }
    Scalar y() const { return m_translation.tensor()[1][0].template item<Scalar>(); }
    Scalar z() const { static_assert(Dim >= 3, "z() only for Dim >= 3"); return m_translation.tensor()[2][0].template item<Scalar>(); }

    Translation operator*(const Translation& other) const {
        return Translation(m_translation + other.vector());
    }

    Matrix<Scalar, Dim, 1> operator*(const Matrix<Scalar, Dim, 1>& vec) const {
        return Matrix<Scalar, Dim, 1>(vec.tensor() + m_translation.tensor());
    }

    Translation inverse() const {
        return Translation(Matrix<Scalar, Dim, 1>(-m_translation.tensor()));
    }
};

using Translation2f = Translation<float, 2>;
using Translation3f = Translation<float, 3>;
using Translation2d = Translation<double, 2>;
using Translation3d = Translation<double, 3>;

} // namespace Eigen
