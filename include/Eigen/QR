#pragma once
#include "Matrix.h"
#include <tuple>

namespace Eigen {

template <typename MatrixType>
class HouseholderQR {
protected:
    at::Tensor m_q;
    at::Tensor m_r;
    bool m_isInitialized = false;

public:
    HouseholderQR() {}

    explicit HouseholderQR(const MatrixType& matrix) {
        compute(matrix);
    }

    HouseholderQR& compute(const MatrixType& matrix) {
        // mode="reduced" matches Eigen's default behavior yielding thin Q and R
        std::tie(m_q, m_r) = torch::linalg_qr(matrix.tensor(), "reduced");
        m_isInitialized = true;
        return *this;
    }

    MatrixType householderQ() const {
        return MatrixType(m_q);
    }

    MatrixType matrixQR() const {
        // This traditionally returns the combined matrix where R is upper triangular 
        // and Householder factors below diagonal. For torch, we just return R.
        return MatrixType(m_r);
    }

    template <typename Rhs>
    Rhs solve(const Rhs& b) const {
        // Ax = b => QRx = b => Rx = Q^T b
        auto rhs = torch::matmul(m_q.adjoint(), b.tensor());
        
        // torch::linalg::solve is general; for an upper triangular R, we could use tri_solve for performance, 
        // but torch::linalg::solve handles general cases just fine
        // Using solve_triangular since R is upper triangular:
        at::Tensor result = torch::linalg_solve_triangular(m_r, rhs, /*upper=*/true, /*left=*/true);
        return Rhs(result);
    }
};

template <typename MatrixType>
class ColPivHouseholderQR {
protected:
    at::Tensor m_a;
    bool m_isInitialized = false;

public:
    ColPivHouseholderQR() {}

    explicit ColPivHouseholderQR(const MatrixType& matrix) {
        compute(matrix);
    }

    ColPivHouseholderQR& compute(const MatrixType& matrix) {
        m_a = matrix.tensor();
        m_isInitialized = true;
        return *this;
    }

    template <typename Rhs>
    Rhs solve(const Rhs& b) const {
        if (!m_isInitialized) {
            throw std::runtime_error("ColPivHouseholderQR is not initialized.");
        }

        // Use CPU's default driver (gelsy) for QR with column pivoting.
        // On CUDA, PyTorch only supports 'gels' (assumes full-rank).
        std::optional<c10::string_view> driver;
        if (!m_a.is_cuda()) {
            driver = c10::string_view("gelsy");
        } else {
            driver = c10::string_view("gels");
        }

        auto out = at::linalg_lstsq(m_a, b.tensor(), /*rcond=*/std::nullopt, driver);
        return Rhs(std::get<0>(out)); // solution
    }
};

template <typename MatrixType>
class FullPivHouseholderQR {
protected:
    at::Tensor m_a;
    bool m_isInitialized = false;

public:
    FullPivHouseholderQR() {}

    explicit FullPivHouseholderQR(const MatrixType& matrix) {
        compute(matrix);
    }

    FullPivHouseholderQR& compute(const MatrixType& matrix) {
        m_a = matrix.tensor();
        m_isInitialized = true;
        return *this;
    }

    template <typename Rhs>
    Rhs solve(const Rhs& b) const {
        if (!m_isInitialized) {
            throw std::runtime_error("FullPivHouseholderQR is not initialized.");
        }

        // Full pivoting is not directly exposed by libtorch; provide Eigen-compatible solve()
        // via a rank-aware least-squares backend.
        std::optional<c10::string_view> driver;
        if (!m_a.is_cuda()) {
            driver = c10::string_view("gelsy");
        } else {
            driver = c10::string_view("gels");
        }

        auto out = at::linalg_lstsq(m_a, b.tensor(), /*rcond=*/std::nullopt, driver);
        return Rhs(std::get<0>(out)); // solution
    }
};

template <typename MatrixType>
class CompleteOrthogonalDecomposition {
protected:
    ColPivHouseholderQR<MatrixType> m_qr;

public:
    CompleteOrthogonalDecomposition() {}

    explicit CompleteOrthogonalDecomposition(const MatrixType& matrix)
        : m_qr(matrix) {}

    CompleteOrthogonalDecomposition& compute(const MatrixType& matrix) {
        m_qr.compute(matrix);
        return *this;
    }

    template <typename Rhs>
    Rhs solve(const Rhs& b) const {
        return m_qr.solve(b);
    }
};

} // namespace Eigen
