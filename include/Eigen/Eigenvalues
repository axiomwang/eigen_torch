#pragma once
#include "Matrix.h"
#include <tuple>

namespace Eigen {

template <typename MatrixType>
class EigenSolver {
protected:
    at::Tensor m_eigenvalues;
    at::Tensor m_eigenvectors;
    bool m_isInitialized = false;

public:
    EigenSolver() {}

    explicit EigenSolver(const MatrixType& matrix, bool computeEigenvectors = true) {
        compute(matrix, computeEigenvectors);
    }

    EigenSolver& compute(const MatrixType& matrix, bool computeEigenvectors = true) {
        if (computeEigenvectors) {
            std::tie(m_eigenvalues, m_eigenvectors) = torch::linalg_eig(matrix.tensor());
        } else {
            m_eigenvalues = torch::linalg_eigvals(matrix.tensor());
        }
        m_isInitialized = true;
        return *this;
    }

    bool info() const {
        return m_isInitialized;
    }

    // PyTorch's eig values always returns a Complex tensor, we must map this appropriately
    // To match exact Eigen signature, true Eigen::MatrixXcf complex types would be needed.
    // For simplicity, we expose the underlying tensor directly or cast to floats if requested
    
    // Returning the raw complex tensor internally packed into Matrix
    // Note: If MatrixType is float, storing complex here is mathematically risky but Torch absorbs it into at::Tensor. 
    MatrixType eigenvalues() const {
        // We ensure we cast back to the real if the user only considers real components, 
        // to conform to typical MatrixXf output unless they truly compiled for Complex.
        return MatrixType(torch::real(m_eigenvalues).unsqueeze(1));
    }

    MatrixType eigenvectors() const {
        return MatrixType(torch::real(m_eigenvectors));
    }
    
    // For pure complex access
    const at::Tensor& complexEigenvalues() const {
        return m_eigenvalues;
    }

    const at::Tensor& complexEigenvectors() const {
        return m_eigenvectors;
    }
};

template <typename MatrixType>
class SelfAdjointEigenSolver {
protected:
    at::Tensor m_eigenvalues;
    at::Tensor m_eigenvectors;
    bool m_isInitialized = false;

public:
    SelfAdjointEigenSolver() {}

    explicit SelfAdjointEigenSolver(const MatrixType& matrix, bool computeEigenvectors = true) {
        compute(matrix, computeEigenvectors);
    }

    SelfAdjointEigenSolver& compute(const MatrixType& matrix, bool computeEigenvectors = true) {
        if (computeEigenvectors) {
            std::tie(m_eigenvalues, m_eigenvectors) = torch::linalg_eigh(matrix.tensor());
        } else {
            m_eigenvalues = std::get<0>(torch::linalg_eigh(matrix.tensor()));
            m_eigenvectors = at::Tensor();
        }
        m_isInitialized = true;
        return *this;
    }

    bool info() const {
        return m_isInitialized;
    }

    Matrix<typename MatrixType::ScalarType, Dynamic, 1> eigenvalues() const {
        return Matrix<typename MatrixType::ScalarType, Dynamic, 1>(m_eigenvalues.unsqueeze(1));
    }

    MatrixType eigenvectors() const {
        return MatrixType(m_eigenvectors);
    }
};

template <typename MatrixType>
class ComplexEigenSolver : public EigenSolver<MatrixType> {
public:
    ComplexEigenSolver() : EigenSolver<MatrixType>() {}

    explicit ComplexEigenSolver(const MatrixType& matrix, bool computeEigenvectors = true)
        : EigenSolver<MatrixType>(matrix, computeEigenvectors) {}

    using EigenSolver<MatrixType>::compute;
    using EigenSolver<MatrixType>::info;
    using EigenSolver<MatrixType>::eigenvalues;
    using EigenSolver<MatrixType>::eigenvectors;
    using EigenSolver<MatrixType>::complexEigenvalues;
    using EigenSolver<MatrixType>::complexEigenvectors;
};

} // namespace Eigen
