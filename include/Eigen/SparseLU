#ifndef EIGEN_SPARSELU_H
#define EIGEN_SPARSELU_H

#include "Matrix.h"
#include "SparseCommon"
#include "SparseMatrix"
#include <tuple>
#include <stdexcept>

namespace Eigen {

template <typename MatrixType_>
class SparseLU {
public:
    using MatrixType = MatrixType_;
    using Scalar = typename MatrixType::ScalarType;

protected:
    at::Tensor m_system;
    at::Tensor m_lu;
    at::Tensor m_pivots;
    at::Tensor m_info_tensor;

    ComputationInfo m_info = InvalidInput;
    bool m_patternAnalyzed = false;
    bool m_isInitialized = false;
    bool m_usedDenseFallback = false;

    void factorizeTensor(const at::Tensor& matrix) {
        at::Tensor work = matrix;

        try {
            std::tie(m_lu, m_pivots, m_info_tensor) = torch::linalg_lu_factor_ex(work);
            m_usedDenseFallback = false;
        } catch (const std::exception&) {
            at::Tensor dense = work.is_sparse() || work.is_sparse_csr() ? work.to_dense() : work;
            std::tie(m_lu, m_pivots, m_info_tensor) = torch::linalg_lu_factor_ex(dense);
            m_usedDenseFallback = true;
        }

        bool lu_ok = !m_info_tensor.defined() || !torch::any(m_info_tensor != 0).item<bool>();
        m_info = lu_ok ? Success : NumericalIssue;
        m_isInitialized = true;
    }

public:
    SparseLU() {}

    explicit SparseLU(const MatrixType& matrix) {
        compute(matrix);
    }

    SparseLU& analyzePattern(const MatrixType& matrix) {
        m_system = matrix.tensor();
        m_patternAnalyzed = true;
        m_info = Success;
        return *this;
    }

    SparseLU& analyzePattern(const at::Tensor& matrix) {
        m_system = matrix;
        m_patternAnalyzed = true;
        m_info = Success;
        return *this;
    }

    SparseLU& factorize(const MatrixType& matrix) {
        m_system = matrix.tensor();
        m_patternAnalyzed = true;
        factorizeTensor(m_system);
        return *this;
    }

    SparseLU& factorize(const at::Tensor& matrix) {
        m_system = matrix;
        m_patternAnalyzed = true;
        factorizeTensor(m_system);
        return *this;
    }

    SparseLU& compute(const MatrixType& matrix) {
        analyzePattern(matrix);
        factorize(matrix);
        return *this;
    }

    template <typename Rhs>
    Rhs solve(const Rhs& b) const {
        if (!m_isInitialized) {
            throw std::runtime_error("SparseLU is not initialized.");
        }

        at::Tensor dense_b;
        if (b.tensor().is_sparse()) {
            dense_b = b.tensor().to_dense();
        } else {
            dense_b = b.tensor();
        }

        at::Tensor result;
        try {
            if (m_system.defined() && (m_system.is_sparse() || m_system.is_sparse_csr()) && !m_usedDenseFallback) {
                result = torch::linalg_solve(m_system, dense_b);
            } else {
                result = torch::linalg_lu_solve(m_lu, m_pivots, dense_b);
            }
        } catch (const std::exception&) {
            result = torch::linalg_lu_solve(m_lu, m_pivots, dense_b);
        }

        return Rhs(result); // Result is always returned dense
    }

    SparseLU& compute(const at::Tensor& matrix) {
        analyzePattern(matrix);
        factorize(matrix);
        return *this;
    }

    ComputationInfo info() const { return m_info; }

    int rows() const {
        return m_system.defined() ? static_cast<int>(m_system.size(0)) : 0;
    }

    int cols() const {
        return m_system.defined() ? static_cast<int>(m_system.size(1)) : 0;
    }

    Matrix<Scalar, Dynamic, Dynamic> matrixL() const {
        if (!m_lu.defined()) {
            throw std::runtime_error("SparseLU matrixL() called before factorization");
        }
        at::Tensor eye = torch::eye(m_lu.size(0), m_lu.options());
        at::Tensor l = torch::tril(m_lu, -1) + eye;
        return Matrix<Scalar, Dynamic, Dynamic>(l);
    }

    Matrix<Scalar, Dynamic, Dynamic> matrixU() const {
        if (!m_lu.defined()) {
            throw std::runtime_error("SparseLU matrixU() called before factorization");
        }
        return Matrix<Scalar, Dynamic, Dynamic>(torch::triu(m_lu));
    }

    const at::Tensor& matrixLU() const { return m_lu; }
    bool usedDenseFallback() const { return m_usedDenseFallback; }
    
};

} // namespace Eigen

#endif // EIGEN_SPARSELU_H
