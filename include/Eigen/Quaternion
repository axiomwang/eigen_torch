#pragma once
#include "Matrix.h"

namespace Eigen {

template <typename Scalar>
class Quaternion {
protected:
    // Layout mimicking Eigen [w, x, y, z] depending on convention. 
    // Usually Eigen stores it internall as [x,y,z,w], but coefficients are ordered w,x,y,z in constructor.
    // We will store as a 4-element 1D tensor [w, x, y, z].
    at::Tensor m_coeffs;

public:
    using ScalarType = Scalar;

    Quaternion() {
        auto options = torch::TensorOptions()
            .dtype(Matrix<Scalar, 4, 1>::get_torch_dtype())
            .device(DeviceManager::get_default_device());
        // Identity quaternion: w=1, x=y=z=0
        m_coeffs = torch::tensor({1.0, 0.0, 0.0, 0.0}, options); 
    }

    static Quaternion Identity() {
        return Quaternion();
    }

    Quaternion(Scalar w, Scalar x, Scalar y, Scalar z) {
        auto options = torch::TensorOptions()
            .dtype(Matrix<Scalar, 4, 1>::get_torch_dtype())
            .device(DeviceManager::get_default_device());
        m_coeffs = torch::tensor({w, x, y, z}, options);
    }
    
    explicit Quaternion(const at::Tensor& tensor) : m_coeffs(tensor) {}

    // Vector3 constructor (representing purely imaginary quaternion)
    // Assumes vector is a 3x1 matrix 
    explicit Quaternion(const Matrix<Scalar, 3, 1>& vec) {
        auto options = torch::TensorOptions()
            .dtype(Matrix<Scalar, 4, 1>::get_torch_dtype())
            .device(DeviceManager::get_default_device());
        // Prepend w=0
        m_coeffs = torch::cat({torch::tensor({0.0}, options), vec.tensor().flatten()});
    }

    const at::Tensor& coeffs() const { return m_coeffs; }
    at::Tensor& coeffs() { return m_coeffs; }

    Scalar w() const { return m_coeffs[0].item<Scalar>(); }
    Scalar x() const { return m_coeffs[1].item<Scalar>(); }
    Scalar y() const { return m_coeffs[2].item<Scalar>(); }
    Scalar z() const { return m_coeffs[3].item<Scalar>(); }

    Quaternion& setIdentity() {
        auto options = torch::TensorOptions()
            .dtype(Matrix<Scalar, 4, 1>::get_torch_dtype())
            .device(DeviceManager::get_default_device());
        m_coeffs = torch::tensor({1.0, 0.0, 0.0, 0.0}, options);
        return *this;
    }

    Scalar squaredNorm() const {
        return torch::dot(m_coeffs, m_coeffs).template item<Scalar>();
    }

    Scalar norm() const {
        return torch::linalg_vector_norm(m_coeffs).template item<Scalar>();
    }

    Scalar dot(const Quaternion& other) const {
        return torch::dot(m_coeffs, other.coeffs()).template item<Scalar>();
    }

    Quaternion conjugate() const {
        auto options = torch::TensorOptions()
            .dtype(Matrix<Scalar, 4, 1>::get_torch_dtype())
            .device(DeviceManager::get_default_device());
        return Quaternion(torch::tensor({w(), -x(), -y(), -z()}, options));
    }

    // Normalize
    void normalize() {
        m_coeffs = m_coeffs / torch::linalg_vector_norm(m_coeffs);
    }

    Quaternion normalized() const {
        return Quaternion(m_coeffs / torch::linalg_vector_norm(m_coeffs));
    }

    // Hamilton product
    Quaternion operator*(const Quaternion& other) const {
        Scalar aw = w(), ax = x(), ay = y(), az = z();
        Scalar bw = other.w(), bx = other.x(), by = other.y(), bz = other.z();
        
        Scalar tw = aw * bw - ax * bx - ay * by - az * bz;
        Scalar tx = aw * bx + ax * bw + ay * bz - az * by;
        Scalar ty = aw * by - ax * bz + ay * bw + az * bx;
        Scalar tz = aw * bz + ax * by - ay * bx + az * bw;
        
        return Quaternion(tw, tx, ty, tz);
    }

    // Multiply by vector (rotates the vector) v' = q * v * q^-1
    Matrix<Scalar, 3, 1> operator*(const Matrix<Scalar, 3, 1>& vec) const {
        Quaternion vec_q(vec);
        Quaternion res = (*this) * vec_q * inverse();
        
        // Return only the imaginary part
        auto options = torch::TensorOptions()
            .dtype(Matrix<Scalar, 3, 1>::get_torch_dtype())
            .device(DeviceManager::get_default_device());
        return Matrix<Scalar, 3, 1>(torch::tensor({res.x(), res.y(), res.z()}, options).unsqueeze(1));
    }

    Quaternion inverse() const {
        Scalar norm_sq = squaredNorm();
        return Quaternion(conjugate().coeffs() / norm_sq);
    }

    Quaternion slerp(Scalar t, const Quaternion& other) const {
        Quaternion q1 = normalized();
        Quaternion q2 = other.normalized();

        Scalar cos_theta = q1.dot(q2);
        if (cos_theta < static_cast<Scalar>(0)) {
            q2 = Quaternion(-q2.coeffs());
            cos_theta = -cos_theta;
        }

        // If very close, use normalized lerp for stability.
        if (cos_theta > static_cast<Scalar>(0.9995)) {
            Quaternion blended((static_cast<Scalar>(1) - t) * q1.coeffs() + t * q2.coeffs());
            blended.normalize();
            return blended;
        }

        Scalar theta = std::acos(cos_theta);
        Scalar sin_theta = std::sin(theta);
        Scalar w1 = std::sin((static_cast<Scalar>(1) - t) * theta) / sin_theta;
        Scalar w2 = std::sin(t * theta) / sin_theta;
        return Quaternion(w1 * q1.coeffs() + w2 * q2.coeffs());
    }
    
    // To Rotation Matrix
    Matrix<Scalar, 3, 3> toRotationMatrix() const {
        Scalar aw = w(), ax = x(), ay = y(), az = z();
        
        auto options = torch::TensorOptions()
            .dtype(Matrix<Scalar, 4, 1>::get_torch_dtype())
            .device(DeviceManager::get_default_device());
            
        at::Tensor rot = torch::tensor({
            1 - 2*ay*ay - 2*az*az, 2*ax*ay - 2*az*aw,     2*ax*az + 2*ay*aw,
            2*ax*ay + 2*az*aw,     1 - 2*ax*ax - 2*az*az, 2*ay*az - 2*ax*aw,
            2*ax*az - 2*ay*aw,     2*ay*az + 2*ax*aw,     1 - 2*ax*ax - 2*ay*ay
        }, options).reshape({3, 3});
        
        return Matrix<Scalar, 3, 3>(rot);
    }

    const at::Tensor& tensor() const { return m_coeffs; }
};

using Quaternionf = Quaternion<float>;
using Quaterniond = Quaternion<double>;

} // namespace Eigen
