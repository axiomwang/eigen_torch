#pragma once
#include "Matrix.h"
#include "Quaternion"
#include <algorithm>
#include <cmath>

namespace Eigen {

template <typename Scalar>
class AngleAxis {
protected:
    Scalar m_angle;
    Matrix<Scalar, 3, 1> m_axis; // Should be normalized

public:
    AngleAxis() : m_angle(0) {
        auto options = torch::TensorOptions()
            .dtype(Matrix<Scalar, 3, 1>::get_torch_dtype())
            .device(DeviceManager::get_default_device());
        m_axis = Matrix<Scalar, 3, 1>(torch::tensor({1.0, 0.0, 0.0}, options).unsqueeze(1));
    }

    AngleAxis(Scalar angle, const Matrix<Scalar, 3, 1>& axis) : m_angle(angle), m_axis(axis) {
        // Assume axis is already normalized, matching Eigen semantics
    }

    explicit AngleAxis(const Quaternion<Scalar>& q) {
        fromQuaternion(q);
    }
    
    Scalar angle() const { return m_angle; }
    const Matrix<Scalar, 3, 1>& axis() const { return m_axis; }
    
    Scalar& angle() { return m_angle; }
    Matrix<Scalar, 3, 1>& axis() { return m_axis; }

    AngleAxis& fromRotationMatrix(const Matrix<Scalar, 3, 3>& rot) {
        Scalar trace = rot(0, 0) + rot(1, 1) + rot(2, 2);
        Scalar cos_theta = (trace - static_cast<Scalar>(1)) / static_cast<Scalar>(2);
        cos_theta = std::max(static_cast<Scalar>(-1), std::min(static_cast<Scalar>(1), cos_theta));
        m_angle = std::acos(cos_theta);

        if (std::abs(m_angle) < static_cast<Scalar>(1e-7)) {
            m_axis = Matrix<Scalar, 3, 1>::UnitX();
            return *this;
        }

        Scalar denom = static_cast<Scalar>(2) * std::sin(m_angle);
        auto options = torch::TensorOptions()
            .dtype(Matrix<Scalar, 3, 1>::get_torch_dtype())
            .device(DeviceManager::get_default_device());
        at::Tensor axis_t = torch::tensor({
            (rot(2, 1) - rot(1, 2)) / denom,
            (rot(0, 2) - rot(2, 0)) / denom,
            (rot(1, 0) - rot(0, 1)) / denom
        }, options).unsqueeze(1);
        m_axis = Matrix<Scalar, 3, 1>(axis_t).normalized();
        return *this;
    }

    AngleAxis& fromQuaternion(const Quaternion<Scalar>& q_in) {
        Quaternion<Scalar> q = q_in.normalized();
        Scalar qw = q.w();
        Scalar qx = q.x();
        Scalar qy = q.y();
        Scalar qz = q.z();

        m_angle = static_cast<Scalar>(2) * std::acos(qw);
        Scalar s = std::sqrt(std::max(static_cast<Scalar>(0), static_cast<Scalar>(1) - qw * qw));

        if (s < static_cast<Scalar>(1e-7)) {
            m_axis = Matrix<Scalar, 3, 1>::UnitX();
        } else {
            auto options = torch::TensorOptions()
                .dtype(Matrix<Scalar, 3, 1>::get_torch_dtype())
                .device(DeviceManager::get_default_device());
            m_axis = Matrix<Scalar, 3, 1>(
                torch::tensor({qx / s, qy / s, qz / s}, options).unsqueeze(1));
        }
        return *this;
    }

    Matrix<Scalar, 3, 3> toRotationMatrix() const {
        // Use Rodrigues' rotation formula
        Scalar c = std::cos(m_angle);
        Scalar s = std::sin(m_angle);
        Scalar C = 1 - c;

        Scalar x = m_axis.tensor()[0][0].template item<Scalar>();
        Scalar y = m_axis.tensor()[1][0].template item<Scalar>();
        Scalar z = m_axis.tensor()[2][0].template item<Scalar>();

        auto options = m_axis.tensor().options();

        at::Tensor rot = torch::tensor({
            x*x*C + c,   x*y*C - z*s, x*z*C + y*s,
            y*x*C + z*s, y*y*C + c,   y*z*C - x*s,
            z*x*C - y*s, z*y*C + x*s, z*z*C + c
        }, options).reshape({3, 3});

        return Matrix<Scalar, 3, 3>(rot);
    }

    // Convert to Quaternion
    explicit operator Quaternion<Scalar>() const {
        Scalar half_angle = m_angle * 0.5;
        Scalar s = std::sin(half_angle);
        Scalar c = std::cos(half_angle);
        
        Scalar x = m_axis.tensor()[0][0].template item<Scalar>() * s;
        Scalar y = m_axis.tensor()[1][0].template item<Scalar>() * s;
        Scalar z = m_axis.tensor()[2][0].template item<Scalar>() * s;
        
        return Quaternion<Scalar>(c, x, y, z);
    }

    Quaternion<Scalar> toQuaternion() const {
        return static_cast<Quaternion<Scalar>>(*this);
    }

    AngleAxis inverse() const {
        return AngleAxis(-m_angle, m_axis);
    }

    Quaternion<Scalar> operator*(const AngleAxis& other) const {
        return this->toQuaternion() * other.toQuaternion();
    }
};

using AngleAxisf = AngleAxis<float>;
using AngleAxisd = AngleAxis<double>;

} // namespace Eigen
