#pragma once
#include "Matrix.h"
#include <tuple>

namespace Eigen {

template <typename MatrixType>
class PartialPivLU {
protected:
    at::Tensor m_lu;
    at::Tensor m_pivots;
    at::Tensor m_info;
    bool m_isInitialized = false;

public:
    PartialPivLU() {}

    explicit PartialPivLU(const MatrixType& matrix) {
        compute(matrix);
    }

    PartialPivLU& compute(const MatrixType& matrix) {
        std::tie(m_lu, m_pivots, m_info) = torch::linalg_lu_factor_ex(matrix.tensor());
        m_isInitialized = true;
        return *this;
    }

    template <typename Rhs>
    Rhs solve(const Rhs& b) const {
        if (!m_isInitialized) {
            throw std::runtime_error("PartialPivLU is not initialized.");
        }
        at::Tensor result = torch::linalg_lu_solve(m_lu, m_pivots, b.tensor());
        return Rhs(result);
    }
    
    MatrixType inverse() const {
        if (!m_isInitialized) {
            throw std::runtime_error("PartialPivLU is not initialized.");
        }
        // solve A * X = I to find the inverse using LU
        auto ident = torch::eye(m_lu.size(0), m_lu.options());
        at::Tensor result = torch::linalg_lu_solve(m_lu, m_pivots, ident);
        return MatrixType(result);
    }
};

template <typename MatrixType>
class FullPivLU {
protected:
    at::Tensor m_a;
    bool m_isInitialized = false;

public:
    FullPivLU() {}

    explicit FullPivLU(const MatrixType& matrix) {
        compute(matrix);
    }

    FullPivLU& compute(const MatrixType& matrix) {
        m_a = matrix.tensor();
        m_isInitialized = true;
        return *this;
    }

    template <typename Rhs>
    Rhs solve(const Rhs& b) const {
        if (!m_isInitialized) {
            throw std::runtime_error("FullPivLU is not initialized.");
        }

        // Full pivoting is not directly exposed by libtorch; provide Eigen-compatible solve()
        // via a robust backend. Prefer direct solve; fall back to least-squares if singular.
        at::Tensor result;
        try {
            result = torch::linalg_solve(m_a, b.tensor());
        } catch (const std::exception&) {
            auto out = at::linalg_lstsq(m_a, b.tensor(), /*rcond=*/std::nullopt, /*driver=*/std::nullopt);
            result = std::get<0>(out); // solution
        }

        return Rhs(result);
    }

    MatrixType inverse() const {
        if (!m_isInitialized) {
            throw std::runtime_error("FullPivLU is not initialized.");
        }
        auto ident = torch::eye(m_a.size(0), m_a.options());
        auto out = at::linalg_lstsq(m_a, ident, /*rcond=*/std::nullopt, /*driver=*/std::nullopt);
        return MatrixType(std::get<0>(out));
    }
};

} // namespace Eigen
