#pragma once
#include "Matrix.h"
#include "Quaternion"
#include "AngleAxis"
#include "Translation"
#include "Scaling"

namespace Eigen {

// Represents an affine transformation Matrix (4x4 for 3D)
template <typename Scalar, int Dim>
class Transform {
protected:
    Matrix<Scalar, Dim + 1, Dim + 1> m_matrix;

public:
    Transform() {
        m_matrix = Matrix<Scalar, Dim + 1, Dim + 1>::Zero(Dim + 1, Dim + 1);
        for (int i = 0; i < Dim + 1; ++i) {
            m_matrix.tensor()[i][i] = 1.0;
        }
    }

    static Transform Identity() {
        return Transform();
    }

    explicit Transform(const Matrix<Scalar, Dim + 1, Dim + 1>& matrix) : m_matrix(matrix) {}

    Transform& setIdentity() {
        m_matrix.setIdentity(Dim + 1, Dim + 1);
        return *this;
    }

    const Matrix<Scalar, Dim + 1, Dim + 1>& matrix() const { return m_matrix; }
    Matrix<Scalar, Dim + 1, Dim + 1>& matrix() { return m_matrix; }

    // Allows T.linear() returning the rotation/scale 3x3 block
    Matrix<Scalar, Dim, Dim> linear() const {
        return m_matrix.block(0, 0, Dim, Dim);
    }

    void linear(const Matrix<Scalar, Dim, Dim>& l) {
        m_matrix.tensor().slice(0, 0, Dim).slice(1, 0, Dim).copy_(l.tensor());
    }

    // Allows T.translation() returning the 3x1 translation block
    Matrix<Scalar, Dim, 1> translation() const {
        return m_matrix.block(0, Dim, Dim, 1);
    }

    void translation(const Matrix<Scalar, Dim, 1>& t) {
        m_matrix.tensor().slice(0, 0, Dim).slice(1, Dim, Dim + 1).copy_(t.tensor());
    }

    Transform operator*(const Transform& other) const {
        return Transform(m_matrix * other.matrix());
    }

    Transform operator*(const Translation<Scalar, Dim>& t) const {
        Transform out(*this);
        out.translate(t);
        return out;
    }

    Transform operator*(const Quaternion<Scalar>& q) const {
        Transform out(*this);
        out.rotate(q);
        return out;
    }

    Transform operator*(const AngleAxis<Scalar>& aa) const {
        Transform out(*this);
        out.rotate(aa);
        return out;
    }

    Transform& operator*=(const Transform& other) {
        m_matrix = m_matrix * other.matrix();
        return *this;
    }

    Matrix<Scalar, Dim, 1> operator*(const Matrix<Scalar, Dim, 1>& vec) const {
        // Append homogeneous coordinate 1.0
        auto options = vec.tensor().options();
        auto hom_coord = torch::tensor({1.0}, options).unsqueeze(0);
        auto vec_hom = torch::cat({vec.tensor(), hom_coord}, 0); 
        
        auto res_hom = m_matrix.tensor().matmul(vec_hom);
        
        // Return only the Dim components
        return Matrix<Scalar, Dim, 1>(res_hom.slice(0, 0, Dim));
    }

    Transform& translate(const Translation<Scalar, Dim>& t) {
        return translate(t.vector());
    }

    Transform& translate(const Matrix<Scalar, Dim, 1>& v) {
        // Right-multiply by translation: t_new = t_old + R * v
        at::Tensor rot = m_matrix.tensor().slice(0, 0, Dim).slice(1, 0, Dim);
        at::Tensor trans = m_matrix.tensor().slice(0, 0, Dim).slice(1, Dim, Dim + 1);
        trans.copy_(trans + torch::matmul(rot, v.tensor()));
        return *this;
    }

    Transform& pretranslate(const Translation<Scalar, Dim>& t) {
        return pretranslate(t.vector());
    }

    Transform& pretranslate(const Matrix<Scalar, Dim, 1>& v) {
        // Left-multiply by translation: t_new = t_old + v
        at::Tensor trans = m_matrix.tensor().slice(0, 0, Dim).slice(1, Dim, Dim + 1);
        trans.copy_(trans + v.tensor());
        return *this;
    }

    Transform& rotate(const Quaternion<Scalar>& q) {
        Matrix<Scalar, Dim, Dim> r = q.toRotationMatrix();
        return rotate(r);
    }

    Transform& rotate(const AngleAxis<Scalar>& aa) {
        Matrix<Scalar, Dim, Dim> r = aa.toRotationMatrix();
        return rotate(r);
    }

    Transform& rotate(const Matrix<Scalar, Dim, Dim>& r) {
        at::Tensor rot = m_matrix.tensor().slice(0, 0, Dim).slice(1, 0, Dim);
        rot.copy_(torch::matmul(rot, r.tensor()));
        return *this;
    }

    Transform& prerotate(const Quaternion<Scalar>& q) {
        Matrix<Scalar, Dim, Dim> r = q.toRotationMatrix();
        return prerotate(r);
    }

    Transform& prerotate(const AngleAxis<Scalar>& aa) {
        Matrix<Scalar, Dim, Dim> r = aa.toRotationMatrix();
        return prerotate(r);
    }

    Transform& prerotate(const Matrix<Scalar, Dim, Dim>& r) {
        at::Tensor rot = m_matrix.tensor().slice(0, 0, Dim).slice(1, 0, Dim);
        at::Tensor trans = m_matrix.tensor().slice(0, 0, Dim).slice(1, Dim, Dim + 1);
        rot.copy_(torch::matmul(r.tensor(), rot));
        trans.copy_(torch::matmul(r.tensor(), trans));
        return *this;
    }

    Transform& scale(Scalar s) {
        at::Tensor rot = m_matrix.tensor().slice(0, 0, Dim).slice(1, 0, Dim);
        rot.copy_(rot * s);
        return *this;
    }

    Transform& scale(const Matrix<Scalar, Dim, 1>& factors) {
        at::Tensor rot = m_matrix.tensor().slice(0, 0, Dim).slice(1, 0, Dim);
        at::Tensor d = torch::diag(factors.tensor().reshape({-1}));
        rot.copy_(torch::matmul(rot, d));
        return *this;
    }

    Transform& scale(const Scaling<Scalar, Dim>& s) {
        return scale(s.factors());
    }

    Transform& prescale(Scalar s) {
        at::Tensor rot = m_matrix.tensor().slice(0, 0, Dim).slice(1, 0, Dim);
        at::Tensor trans = m_matrix.tensor().slice(0, 0, Dim).slice(1, Dim, Dim + 1);
        rot.copy_(s * rot);
        trans.copy_(s * trans);
        return *this;
    }

    Transform& prescale(const Matrix<Scalar, Dim, 1>& factors) {
        at::Tensor rot = m_matrix.tensor().slice(0, 0, Dim).slice(1, 0, Dim);
        at::Tensor trans = m_matrix.tensor().slice(0, 0, Dim).slice(1, Dim, Dim + 1);
        at::Tensor d = torch::diag(factors.tensor().reshape({-1}));
        rot.copy_(torch::matmul(d, rot));
        trans.copy_(torch::matmul(d, trans));
        return *this;
    }

    Transform& prescale(const Scaling<Scalar, Dim>& s) {
        return prescale(s.factors());
    }
    
    Transform inverse() const {
        return Transform(m_matrix.inverse());
    }
};

using Affine3f = Transform<float, 3>;
using Affine3d = Transform<double, 3>;
using Isometry3f = Transform<float, 3>;
using Isometry3d = Transform<double, 3>;

} // namespace Eigen
