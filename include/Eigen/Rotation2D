#ifndef EIGEN_ROTATION2D_H
#define EIGEN_ROTATION2D_H

#include "Matrix.h"
#include <cmath>

namespace Eigen {

template <typename Scalar_>
class Rotation2D {
public:
    using Scalar = Scalar_;
    using ScalarType = Scalar_;

protected:
    Scalar m_angle;

public:
    Rotation2D() : m_angle(0) {}
    explicit Rotation2D(Scalar angle) : m_angle(angle) {}

    explicit Rotation2D(const Matrix<Scalar, 2, 2>& matrix) {
        fromRotationMatrix(matrix);
    }

    Scalar angle() const { return m_angle; }
    Scalar& angle() { return m_angle; }

    Rotation2D& fromRotationMatrix(const Matrix<Scalar, 2, 2>& matrix) {
        m_angle = std::atan2(matrix(1, 0), matrix(0, 0));
        return *this;
    }

    Matrix<Scalar, 2, 2> toRotationMatrix() const {
        Scalar s = std::sin(m_angle);
        Scalar c = std::cos(m_angle);
        auto options = torch::TensorOptions()
            .dtype(Matrix<Scalar, 2, 2>::get_torch_dtype())
            .device(DeviceManager::get_default_device());

        at::Tensor mat = torch::tensor({{c, -s}, {s, c}}, options);
        return Matrix<Scalar, 2, 2>(mat);
    }

    Matrix<Scalar, 2, 1> operator*(const Matrix<Scalar, 2, 1>& vec) const {
        return Matrix<Scalar, 2, 1>(torch::matmul(toRotationMatrix().tensor(), vec.tensor()));
    }

    Rotation2D operator*(const Rotation2D& other) const {
        return Rotation2D(m_angle + other.angle());
    }

    Rotation2D inverse() const {
        return Rotation2D(-m_angle);
    }

    Rotation2D& operator*=(const Rotation2D& other) {
        m_angle += other.angle();
        return *this;
    }
};

using Rotation2Df = Rotation2D<float>;
using Rotation2Dd = Rotation2D<double>;

} // namespace Eigen

#endif // EIGEN_ROTATION2D_H
